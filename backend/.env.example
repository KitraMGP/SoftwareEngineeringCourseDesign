APP_NAME=private-kb-qa
APP_ENV=development
HTTP_ADDR=:8080

DATABASE_DSN=postgres://postgres:postgres@localhost:55432/private_kb_qa?sslmode=disable
DATABASE_MAX_CONNS=10
DATABASE_MIN_CONNS=2
DATABASE_MAX_CONN_IDLE_TIME=15m
DATABASE_MAX_CONN_LIFETIME=1h

AUTH_ISSUER=private-kb-qa
AUTH_JWT_SECRET=change-this-secret
AUTH_ACCESS_TOKEN_TTL=30m
AUTH_REFRESH_TOKEN_TTL=168h
AUTH_REFRESH_COOKIE_NAME=refresh_token
AUTH_REFRESH_COOKIE_PATH=/api/v1/auth
AUTH_REFRESH_COOKIE_SECURE=false

TASK_POLL_INTERVAL=5s

STORAGE_PROVIDER=local_fs
STORAGE_BUCKET=local-dev
STORAGE_LOCAL_ROOT=./data/storage
STORAGE_MAX_UPLOAD_BYTES=20971520
